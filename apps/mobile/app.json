{
  "expo": {
    "name": "SIMCHA OS",
    "slug": "simcha-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "simcha",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#6366f1",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.simcha.os",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "האפליקציה משתמשת במיקרופון לעוזר הקולי",
        "NSSpeechRecognitionUsageDescription": "זיהוי דיבור מאפשר לשאול את העוזר בקול"
      }
    },
    "android": {
      "package": "io.simcha.os",
      "permissions": ["RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#6366f1"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["@react-native-voice/voice", {
        "microphonePermission": "האפליקציה משתמשת במיקרופון לעוזר הקולי",
        "speechRecognitionPermission": "זיהוי דיבור מאפשר לשאול את העוזר בקול"
      }]
    ],
    "extra": {
      "apiUrl": "http://10.0.2.2:4000/v1",
      "demo": true
    }
  }
}
