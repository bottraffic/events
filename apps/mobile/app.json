{
  "expo": {
    "name": "events360",
    "slug": "events360",
    "owner": "bottraffic",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "simcha",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#6366f1",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.simcha.os",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "האפליקציה משתמשת במיקרופון לעוזר הקולי",
        "NSSpeechRecognitionUsageDescription": "זיהוי דיבור מאפשר לשאול את העוזר בקול"
      }
    },
    "android": {
      "package": "io.simcha.os",
      "versionCode": 3,
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "האפליקציה משתמשת במיקרופון לעוזר הקולי",
          "speechRecognitionPermission": "זיהוי דיבור מאפשר לשאול את העוזר בקול"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://events.webon.org.il/v1",
      "demo": true,
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f276fe0a-d4bf-4e86-a02b-5825d1cda56d"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f276fe0a-d4bf-4e86-a02b-5825d1cda56d"
    }
  }
}
