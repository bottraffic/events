{
  "expo": {
    "name": "events360",
    "slug": "events360",
    "owner": "bottraffic",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "simcha",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0c6ca8",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.simcha.os"
    },
    "android": {
      "package": "io.simcha.os",
      "versionCode": 9,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c6ca8"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "האפליקציה ניגשת לתמונות כדי להעלות את לוגו האולם"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://events.webon.org.il/v1",
      "demo": true,
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f276fe0a-d4bf-4e86-a02b-5825d1cda56d"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f276fe0a-d4bf-4e86-a02b-5825d1cda56d"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
