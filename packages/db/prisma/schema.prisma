// SIMCHA OS — Prisma schema (MySQL)
// Multi-Tenant SaaS for event venues.
// MySQL has no Row-Level Security, so tenant isolation is enforced at the API
// layer: every query filters by tenantId. Scalar-array fields are stored as JSON
// (MySQL does not support scalar lists). Soft-delete via deletedAt.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------
enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum Plan {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum RoleLevel {
  ADMIN
  SALES_MANAGER
  AGENT
  SERVICE
  VIEWER
}

enum LeadSource {
  FACEBOOK
  INSTAGRAM
  GOOGLE_ADS
  TIKTOK
  WHATSAPP
  WEBSITE
  PHONE
  REFERRAL
  OTHER
}

enum StageType {
  OPEN
  WON
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  NOTE
  STAGE_CHANGE
  TASK
  MEETING
}

enum EventStatus {
  INQUIRY
  OPTION
  BOOKED
  COMPLETED
  CANCELLED
}

enum RsvpStatus {
  PENDING
  YES
  NO
  MAYBE
}

enum TableType {
  ROUND
  RECTANGLE
  VIP
}

enum ConstraintRule {
  TOGETHER
  APART
}

enum Channel {
  WHATSAPP
  EMAIL
  SMS
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  DECLINED
  EXPIRED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskSource {
  MANUAL
  AI
  AUTOMATION
  REMINDER
}

enum NotificationType {
  NEW_LEAD
  NEW_MESSAGE
  RSVP
  CONTRACT_SIGNED
  TASK
  CALL
  SYSTEM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

// ---------------------------------------------------------------------------
// TENANCY & AUTH
// ---------------------------------------------------------------------------
model Tenant {
  id           String       @id @default(uuid())
  name         String
  slug         String       @unique
  subdomain    String       @unique
  customDomain String?      @unique
  plan         Plan         @default(STARTER)
  status       TenantStatus @default(TRIAL)
  settings     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  users          User[]
  roles          Role[]
  leads          Lead[]
  pipelineStages PipelineStage[]
  customers      Customer[]
  events         Event[]
  halls          Hall[]
  campaigns      Campaign[]
  conversations  Conversation[]
  contracts      Contract[]
  vendors        Vendor[]
  tasks          Task[]
  automations    Automation[]
  notifications  Notification[]
  files          File[]
  auditLogs      AuditLog[]
  subscriptions  Subscription[]
  aiJobs         AiJob[]
  reminders      Reminder[]
  guestGroups    GuestGroup[]
  templates      MessageTemplate[]
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  name         String
  email        String
  phone        String?
  passwordHash String
  avatarUrl    String?
  status       String    @default("active")
  pushToken    String?   // Expo push token for mobile notifications
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  userRoles       UserRole[]
  oauthAccounts   OauthAccount[]
  sessions        Session[]
  assignedLeads   Lead[]           @relation("LeadAssignee")
  leadActivities  LeadActivity[]
  tasks           Task[]           @relation("TaskAssignee")
  notifications   Notification[]
  aiConversations AiConversation[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id       String    @id @default(uuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  name     String
  level    RoleLevel
  isSystem Boolean   @default(false)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([tenantId])
}

model Permission {
  id     String @id @default(uuid())
  key    String @unique
  module String
  action String

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model OauthAccount {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String
  tokens    Json
  scopes    Json?
  createdAt DateTime @default(now())

  @@unique([userId, provider])
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  device           String?
  ip               String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// CRM & SALES
// ---------------------------------------------------------------------------
model PipelineStage {
  id       String    @id @default(uuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  name     String
  order    Int
  color    String    @default("#6366f1")
  type     StageType @default(OPEN)

  leads Lead[]

  @@index([tenantId])
}

model Lead {
  id             String         @id @default(uuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  name           String
  phone          String?
  email          String?
  source         LeadSource     @default(OTHER)
  stageId        String?
  stage          PipelineStage? @relation(fields: [stageId], references: [id])
  notes          String?        @db.Text
  estimatedValue Decimal?       @db.Decimal(12, 2)
  score          Int?
  assignedToId   String?
  assignedTo     User?          @relation("LeadAssignee", fields: [assignedToId], references: [id])
  campaignId     String?
  campaign       Campaign?      @relation(fields: [campaignId], references: [id])
  customerId     String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  activities LeadActivity[]
  reminders  Reminder[]
  calls      Call[]

  @@index([tenantId])
  @@index([tenantId, stageId])
  @@index([tenantId, phone])
}

model LeadActivity {
  id        String       @id @default(uuid())
  tenantId  String
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      ActivityType
  payload   Json?
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@index([leadId])
}

model Customer {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  name         String
  partnerName  String?
  phone        String?
  email        String?
  address      String?
  sourceLeadId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  leads         Lead[]
  events        Event[]
  contracts     Contract[]
  conversations Conversation[]

  @@index([tenantId])
}

model Reminder {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  entityType String
  entityId   String
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id])
  dueAt      DateTime
  message    String?
  channel    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([tenantId, dueAt])
}

// ---------------------------------------------------------------------------
// EVENTS & GUESTS
// ---------------------------------------------------------------------------
model Hall {
  id          String  @id @default(uuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  name        String
  capacity    Int
  layout      Json?
  description String?

  events Event[]

  @@index([tenantId])
}

model Event {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  type        String      @default("wedding")
  eventDate   DateTime
  startTime   String?
  hallId      String?
  hall        Hall?       @relation(fields: [hallId], references: [id])
  guestsCount Int         @default(0)
  status      EventStatus @default(INQUIRY)
  totalPrice  Decimal?    @db.Decimal(12, 2)
  depositPaid Decimal?    @db.Decimal(12, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  checklistItems EventChecklistItem[]
  guests         EventGuest[]
  invitations    Invitation[]
  seatingCharts  SeatingChart[]
  contracts      Contract[]
  eventVendors   EventVendor[]
  constraints    SeatingConstraint[]

  @@index([tenantId])
  @@index([tenantId, eventDate])
}

model EventChecklistItem {
  id       String    @id @default(uuid())
  tenantId String
  eventId  String
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title    String
  done     Boolean   @default(false)
  dueDate  DateTime?
  assignee String?

  @@index([eventId])
}

model GuestGroup {
  id       String       @id @default(uuid())
  tenantId String
  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  eventId  String
  name     String
  color    String       @default("#10b981")

  guests EventGuest[]

  @@index([eventId])
}

model EventGuest {
  id        String      @id @default(uuid())
  tenantId  String
  eventId   String
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  groupId   String?
  group     GuestGroup? @relation(fields: [groupId], references: [id])
  name      String
  phone     String?
  partySize Int         @default(1)
  dietary   String?
  status    RsvpStatus  @default(PENDING)
  tableId   String?
  createdAt DateTime    @default(now())

  rsvpResponses   RsvpResponse[]
  seatAssignments SeatAssignment[]

  @@index([eventId])
  @@index([eventId, status])
}

model Invitation {
  id         String   @id @default(uuid())
  tenantId   String
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  templateId String?
  design     Json?
  mediaUrls  Json?
  mapLat     Float?
  mapLng     Float?
  slug       String   @unique
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())

  rsvpResponses RsvpResponse[]

  @@index([eventId])
}

model RsvpResponse {
  id           String      @id @default(uuid())
  tenantId     String
  guestId      String
  guest        EventGuest  @relation(fields: [guestId], references: [id], onDelete: Cascade)
  invitationId String?
  invitation   Invitation? @relation(fields: [invitationId], references: [id])
  status       RsvpStatus
  partySize    Int         @default(1)
  message      String?
  ip           String?
  respondedAt  DateTime    @default(now())

  @@index([guestId])
}

// ---------------------------------------------------------------------------
// SEATING
// ---------------------------------------------------------------------------
model SeatingChart {
  id        String   @id @default(uuid())
  tenantId  String
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  version   Int      @default(1)
  isActive  Boolean  @default(false)
  canvas    Json?
  createdAt DateTime @default(now())

  tables Table[]

  @@index([eventId])
}

model Table {
  id       String       @id @default(uuid())
  tenantId String
  chartId  String
  chart    SeatingChart @relation(fields: [chartId], references: [id], onDelete: Cascade)
  type     TableType    @default(ROUND)
  x        Float        @default(0)
  y        Float        @default(0)
  seats    Int          @default(10)
  label    String?

  assignments SeatAssignment[]

  @@index([chartId])
}

model SeatAssignment {
  id        String     @id @default(uuid())
  tenantId  String
  tableId   String
  table     Table      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guestId   String
  guest     EventGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  seatIndex Int

  @@unique([tableId, seatIndex])
  @@index([guestId])
}

model SeatingConstraint {
  id       String         @id @default(uuid())
  tenantId String
  eventId  String
  event    Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestA   String
  guestB   String
  rule     ConstraintRule

  @@index([eventId])
}

// ---------------------------------------------------------------------------
// TELEPHONY
// ---------------------------------------------------------------------------
model Campaign {
  id       String   @id @default(uuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  name     String
  channel  String
  budget   Decimal? @db.Decimal(12, 2)
  utm      Json?
  status   String   @default("active")

  trackingNumbers TrackingNumber[]
  leads           Lead[]

  @@index([tenantId])
}

model TrackingNumber {
  id          String    @id @default(uuid())
  tenantId    String
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  phoneNumber String
  provider    String
  status      String    @default("active")

  calls Call[]

  @@index([tenantId])
}

model Call {
  id               String          @id @default(uuid())
  tenantId         String
  trackingNumberId String?
  trackingNumber   TrackingNumber? @relation(fields: [trackingNumberId], references: [id])
  leadId           String?
  lead             Lead?           @relation(fields: [leadId], references: [id])
  direction        CallDirection
  fromNumber       String
  toNumber         String
  duration         Int             @default(0)
  recordingUrl     String?
  status           String          @default("completed")
  startedAt        DateTime        @default(now())

  aiInsight CallAiInsight?

  @@index([tenantId])
}

model CallAiInsight {
  id               String   @id @default(uuid())
  tenantId         String
  callId           String   @unique
  call             Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  transcript       String?  @db.Text
  summary          String?  @db.Text
  sentiment        String?
  needs            String?
  budget           String?
  eventDate        String?
  closeProbability Int?
  createdAt        DateTime @default(now())
}

// ---------------------------------------------------------------------------
// MESSAGING
// ---------------------------------------------------------------------------
model Conversation {
  id            String    @id @default(uuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  channel       Channel
  contactPhone  String?
  contactEmail  String?
  leadId        String?
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  lastMessageAt DateTime?
  status        String    @default("open")
  createdAt     DateTime  @default(now())

  messages Message[]

  @@index([tenantId])
}

model Message {
  id             String           @id @default(uuid())
  tenantId       String
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  body           String?          @db.Text
  mediaUrls      Json?
  status         MessageStatus    @default(QUEUED)
  externalId     String?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
}

model MessageTemplate {
  id               String  @id @default(uuid())
  tenantId         String
  tenant           Tenant  @relation(fields: [tenantId], references: [id])
  channel          Channel
  name             String
  body             String  @db.Text
  variables        Json?
  waTemplateStatus String?

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// CONTRACTS
// ---------------------------------------------------------------------------
model Contract {
  id         String         @id @default(uuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  eventId    String?
  event      Event?         @relation(fields: [eventId], references: [id])
  customerId String?
  customer   Customer?      @relation(fields: [customerId], references: [id])
  title      String
  bodyHtml   String?        @db.Text
  status     ContractStatus @default(DRAFT)
  fileUrl    String?
  mergeData  Json?
  signToken  String?        @unique
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  signatures ContractSignature[]
  auditTrail ContractAuditTrail[]

  @@index([tenantId])
}

model ContractSignature {
  id           String   @id @default(uuid())
  tenantId     String
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  signerName   String
  signatureImg String?  @db.Text
  signedAt     DateTime @default(now())
  ip           String?
  device       String?
  hash         String?

  @@index([contractId])
}

model ContractAuditTrail {
  id         String   @id @default(uuid())
  tenantId   String
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  action     String
  ip         String?
  userAgent  String?
  meta       Json?
  timestamp  DateTime @default(now())

  @@index([contractId])
}

// ---------------------------------------------------------------------------
// VENDORS & TASKS
// ---------------------------------------------------------------------------
model Vendor {
  id       String  @id @default(uuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  name     String
  category String
  phone    String?
  email    String?
  rating   Int?
  notes    String? @db.Text

  eventVendors EventVendor[]

  @@index([tenantId])
}

model EventVendor {
  id          String   @id @default(uuid())
  tenantId    String
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  status      String   @default("pending")
  cost        Decimal? @db.Decimal(12, 2)
  contractUrl String?

  @@index([eventId])
}

model Task {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  title       String
  description String?      @db.Text
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dueAt       DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)
  relatedType String?
  relatedId   String?
  source      TaskSource   @default(MANUAL)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

// ---------------------------------------------------------------------------
// AUTOMATION & AI
// ---------------------------------------------------------------------------
model Automation {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  triggerType String
  conditions  Json?
  actions     Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  runs AutomationRun[]

  @@index([tenantId])
}

model AutomationRun {
  id             String     @id @default(uuid())
  tenantId       String
  automationId   String
  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  triggerPayload Json?
  status         String
  log            Json?
  executedAt     DateTime   @default(now())

  @@index([automationId])
}

model AiConversation {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  messages  Json?
  context   Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model AiJob {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  type      String
  provider  String
  prompt    String?  @db.Text
  response  String?  @db.Text
  tokens    Int      @default(0)
  cost      Decimal  @default(0) @db.Decimal(12, 6)
  status    String   @default("done")
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// REPORTS, BILLING, SYSTEM
// ---------------------------------------------------------------------------
model Subscription {
  id               String             @id @default(uuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  plan             Plan
  status           SubscriptionStatus @default(TRIALING)
  currentPeriodEnd DateTime?
  seats            Int                @default(1)
  stripeId         String?
  createdAt        DateTime           @default(now())

  invoices     Invoice[]
  usageRecords UsageRecord[]

  @@index([tenantId])
}

model Invoice {
  id             String       @id @default(uuid())
  tenantId       String
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Decimal      @db.Decimal(12, 2)
  status         String       @default("paid")
  pdfUrl         String?
  externalId     String?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId])
}

model UsageRecord {
  id             String       @id @default(uuid())
  tenantId       String
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  metric         String
  quantity       Int
  period         String
  createdAt      DateTime     @default(now())

  @@index([subscriptionId, period])
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  readAt    DateTime?
  pushSent  Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

model File {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  ownerType  String
  ownerId    String
  s3Key      String
  mime       String
  size       Int
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model WebhookInbox {
  id         String   @id @default(uuid())
  provider   String
  payload    Json?
  processed  Boolean  @default(false)
  receivedAt DateTime @default(now())

  @@index([provider, processed])
}

model FeatureFlag {
  id       String  @id @default(uuid())
  tenantId String?
  key      String
  enabled  Boolean @default(false)
  rollout  Int     @default(0)

  @@unique([tenantId, key])
}
