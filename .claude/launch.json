{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-demo",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "apps/web"],
      "port": 3000,
      "autoPort": true,
      "env": { "NEXT_PUBLIC_DEMO": "1" }
    },
    {
      "name": "web-live",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "apps/web"],
      "port": 3000,
      "autoPort": true,
      "env": { "NEXT_PUBLIC_DEMO": "0", "NEXT_PUBLIC_API_URL": "https://events.webon.org.il/v1" }
    }
  ]
}
